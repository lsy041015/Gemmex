{
  "suite_name": "coding_capability_eval",
  "version": "1.0",
  "description": "코딩 에이전트 성능 측정을 위한 태스크 기반 eval",
  "evals": [
    {
      "id": "debug-001",
      "category": "debugging",
      "prompt": "pytest 실패 로그를 보고 원인 분석 후 최소 수정으로 고쳐줘.",
      "inputs": [],
      "expected_artifacts": [
        "수정된 소스 파일",
        "실행 로그"
      ],
      "verification": {
        "commands": [
          "pytest -q"
        ],
        "pass_criteria": [
          "pytest 종료코드가 0이다",
          "실패 테스트 수가 0이다"
        ]
      }
    },
    {
      "id": "testgen-001",
      "category": "test_generation",
      "prompt": "핵심 함수 2개에 대해 pytest 단위 테스트를 추가해줘.",
      "inputs": [],
      "expected_artifacts": [
        "tests/ 하위 신규 테스트 파일"
      ],
      "verification": {
        "commands": [
          "pytest -q"
        ],
        "pass_criteria": [
          "신규 테스트 파일이 생성되었다",
          "전체 테스트가 통과한다"
        ]
      }
    },
    {
      "id": "multifile-001",
      "category": "multi_file_edit",
      "prompt": "설정값 이름 변경을 여러 모듈에 일관되게 반영하고 실행 가능하게 수정해줘.",
      "inputs": [],
      "expected_artifacts": [
        "2개 이상 파일 수정"
      ],
      "verification": {
        "commands": [
          "python3 -m py_compile $(rg --files -g '*.py')"
        ],
        "pass_criteria": [
          "문법 오류가 없다",
          "누락 import/참조 오류가 없다"
        ]
      }
    },
    {
      "id": "refactor-001",
      "category": "refactoring",
      "prompt": "중복 로직을 함수로 추출해 가독성을 높이고 기존 동작은 유지해줘.",
      "inputs": [],
      "expected_artifacts": [
        "리팩토링된 소스 파일"
      ],
      "verification": {
        "commands": [
          "pytest -q"
        ],
        "pass_criteria": [
          "기존 테스트가 모두 통과한다",
          "중복 코드 라인이 감소한다"
        ]
      }
    }
  ],
  "metrics": [
    "success_rate",
    "first_pass_rate",
    "retry_success_rate",
    "p95_latency",
    "tokens_per_task"
  ]
}
